generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement()) @map("CustomerID")
  firstName String    @map("FName") @db.VarChar(100)
  lastName  String    @map("LName") @db.VarChar(100)
  username  String    @unique @map("Username") @db.VarChar(100)
  password  String?   @map("Password") @db.VarChar(255)
  phone     String?   @map("CTel") @db.VarChar(12)
  email     String    @unique @map("CEmail") @db.VarChar(255)
  googleId  String?   @unique @map("GoogleID") @db.VarChar(255)
  profileImageUrl String? @map("ProfileImageUrl") @db.VarChar(512)
  bookings  Booking[] @relation("CustomerBookings")
  reports   CustomerReport[]  @relation("CustomerReports")

  @@map("customer")
}

model Host {
  id         Int         @id @default(autoincrement()) @map("HostID")
  firstName  String      @map("FName") @db.VarChar(100)
  lastName   String      @map("LName") @db.VarChar(100)
  username   String      @unique @map("Username") @db.VarChar(100)
  password   String      @map("Password") @db.VarChar(255)
  phone      String      @map("Htel") @db.VarChar(12)
  email      String      @unique @map("HEmail") @db.VarChar(255)
  googleId   String?     @unique @map("GoogleID") @db.VarChar(255)
  profileImageUrl String? @map("ProfileImageUrl") @db.VarChar(512)
  simulators Simulator[]

  @@map("host")
}

model Country {
  id        Int        @id @map("CountryID")
  name      String     @unique @map("CountryName") @db.VarChar(100)
  code      String     @unique @map("CountryCode") @db.VarChar(2)
  provinces Province[]
  cities    City[]

  @@map("country")
}

model Province {
  id        Int      @id @map("ProvinceID")
  name      String   @map("ProvinceName") @db.VarChar(100)
  code      String?  @map("ProvinceCode") @db.VarChar(10)
  countryId Int      @map("CountryID")
  country   Country  @relation(fields: [countryId], references: [id])
  cities    City[]

  @@map("province")
}

model City {
  id         Int        @id @map("CityID")
  name       String     @map("CityName") @db.VarChar(100)
  provinceId Int?       @map("ProvinceID")
  countryId  Int        @map("CountryID")
  province   Province?  @relation(fields: [provinceId], references: [id])
  country    Country    @relation(fields: [countryId], references: [id])
  simulators Simulator[]

  @@map("city")
}

model SimulatorType {
  id       Int                 @id @default(autoincrement()) @map("SimTypeID")
  typeName String              @map("SimTypeName") @db.VarChar(32)
  typeList SimulatorTypeList[]

  @@map("simulatortype")
}

model SimulatorTypeList {
  simTypeId Int           @map("SimTypeID")
  simId     Int           @map("SimID")
  simulator Simulator     @relation(fields: [simId], references: [id])
  simType   SimulatorType @relation(fields: [simTypeId], references: [id])

  @@id([simTypeId, simId])
  @@map("simulatortypelist")
}

model SimulatorBrand {
  id        Int            @id @default(autoincrement()) @map("BrandID")
  brandName String         @map("BrandName") @db.VarChar(32)
  models    SimulatorMod[]
  pedals    Pedal[]        @relation("PedalBrand")

  @@map("simulatorbrand")
}

model SimulatorMod {
  id          Int            @id @default(autoincrement()) @map("ModID")
  modelName   String         @map("ModelName") @db.VarChar(100)
  description String?        @map("Description")
  brandId     Int            @map("BrandID")
  simulators  Simulator[]
  brand       SimulatorBrand @relation(fields: [brandId], references: [id])

  @@map("simulatormodel")
}

model Pedal {
  id          Int            @id @default(autoincrement()) @map("PedalID")
  modelName   String         @map("ModelName") @db.VarChar(100)
  description String?        @map("Description")
  brandId     Int            @map("BrandID")
  simulators  Simulator[]
  brand       SimulatorBrand @relation("PedalBrand", fields: [brandId], references: [id])

  @@map("pedalmodel")
}

model Platform {
  id          Int         @id @default(autoincrement()) @map("PlatformID")
  name        String      @map("Name") @db.VarChar(50)
  description String?     @map("Description") @db.VarChar(200)
  simulators  Simulator[]

  @@map("platform")
}

model ScreenSetup {
  id          Int         @id @default(autoincrement()) @map("ScreenSetupID")
  name        String      @map("Name") @db.VarChar(50)
  description String?     @map("Description") @db.VarChar(200)
  simulators  Simulator[]

  @@map("screensetup")
}

model Simulator {
  id              Int                 @id @default(autoincrement()) @map("SimID")
  simListName     String              @map("SimListName") @db.VarChar(255)
  pricePerHour    Decimal             @map("PricePerHour") @db.Decimal(10, 2)
  listDescription String?             @map("ListDescription")
  addressDetail   String              @map("AddressDetail")
  cityId          Int                 @map("CityID")
  latitude        Decimal             @map("Lat") @db.Decimal(10, 8)
  longitude       Decimal             @map("Long") @db.Decimal(11, 8)
  firstImage      String              @default("noimage.webp") @map("firstimage") @db.VarChar(255)
  secondImage     String              @default("noimage.webp") @map("secondimage") @db.VarChar(255)
  thirdImage      String              @default("noimage.webp") @map("thirdimage") @db.VarChar(255)
  platformId      Int?                @map("PlatformID")
  pedalId         Int?                @map("PedalID")
  screenSetupId   Int?                @map("ScreenSetupID")
  hostId          Int                 @map("HostID")
  modId           Int                 @map("ModID")
  bookings        Booking[]
  city            City                @relation(fields: [cityId], references: [id])
  host            Host                @relation(fields: [hostId], references: [id])
  mod             SimulatorMod        @relation(fields: [modId], references: [id])
  platform        Platform?           @relation(fields: [platformId], references: [id])
  pedal           Pedal?              @relation(fields: [pedalId], references: [id])
  screenSetup     ScreenSetup?        @relation(fields: [screenSetupId], references: [id])
  schedules       SimulatorSchedule[]
  scheduleTemplates ScheduleTemplate[]
  typeList        SimulatorTypeList[]
  facilities       SimulatorFacility[]

  @@map("simulatorlist")
}

model ScheduleTemplate {
  id           Int                 @id @default(autoincrement()) @map("TemplateID")
  dayOfWeek    Int                 @map("DayOfWeek") @db.SmallInt
  startTime    DateTime            @map("StartTime") @db.Time(0)
  endTime      DateTime            @map("EndTime") @db.Time(0)
  pricePerHour Decimal             @map("PricePerHour") @db.Decimal(10, 2)
  isActive     Boolean             @default(true) @map("IsActive")
  simId        Int                 @map("SimID")
  simulator    Simulator           @relation(fields: [simId], references: [id])
  schedules    SimulatorSchedule[]

  @@unique([simId, dayOfWeek, startTime, endTime])
  @@map("scheduletemplate")
}

model SimulatorSchedule {
  id          Int                @id @default(autoincrement()) @map("ScheduleID")
  price       Decimal            @map("Price") @db.Decimal(10, 2)
  date        DateTime           @map("Date") @db.Date
  startTime   DateTime           @map("StartTime") @db.Time(0)
  endTime     DateTime           @map("EndTime") @db.Time(0)
  available   Boolean            @default(true) @map("Available")
  simId       Int                @map("SimID")
  templateId  Int?               @map("TemplateID")
  bookingList BookingList[]
  simulator   Simulator          @relation(fields: [simId], references: [id])
  template    ScheduleTemplate?  @relation(fields: [templateId], references: [id])

  @@unique([simId, date, startTime])
  @@index([simId, date, available])
  @@index([date, available, startTime])
  @@map("simulatorschedule")
}

model BookingStatus {
  id         Int       @id @default(autoincrement()) @map("StatusID")
  statusName String    @map("Statusname") @db.VarChar(16)
  bookings   Booking[]

  @@map("bookingstatus")
}

model Booking {
  id            Int           @id @default(autoincrement()) @map("BookingID")
  bookingDate   DateTime      @default(now()) @map("BookingDate") @db.Timestamptz(6)
  totalPrice    Decimal       @map("TotalPrice") @db.Decimal(10, 2)
  statusId      Int           @default(1) @map("StatusID")
  customerId    Int           @map("CustomerID")
  simId         Int           @map("SimID")
  customer      User          @relation("CustomerBookings", fields: [customerId], references: [id])
  simulator     Simulator     @relation(fields: [simId], references: [id])
  bookingStatus BookingStatus @relation(fields: [statusId], references: [id])
  bookingList   BookingList[]
  review        SimulatorReview?
  customerReviews CustomerReview[] @relation("BookingCustomerReview")

  @@map("booking")
}

model BookingList {
  bookingId  Int               @map("BookingID")
  scheduleId Int               @map("ScheduleID")
  booking    Booking           @relation(fields: [bookingId], references: [id])
  schedule   SimulatorSchedule @relation(fields: [scheduleId], references: [id])

  @@id([bookingId, scheduleId])
  @@map("bookinglist")
}

model SimulatorReview {
  id         Int       @id @default(autoincrement()) @map("ReviewID")
  comment    String?   @map("Comment") @db.VarChar(1000)
  overallRating Float     @map("OverallRating") @db.DoublePrecision
  bookingId  Int       @map("BookingID") @unique
  booking    Booking   @relation(fields: [bookingId], references: [id])
  reviewList SimulatorReviewList[]

  @@map("review")
}

model SimulatorReviewType {
  id         Int       @id @default(autoincrement()) @map("ReviewTypeID")
  typeName   String    @map("TypeName") @db.VarChar(32)
  reviews    SimulatorReviewList[]

  @@map("reviewtype")
}

model SimulatorReviewList {
  reviewId   Int       @map("ReviewID")
  typeId     Int       @map("TypeID")
  rating     Int       @map("Rating") @db.SmallInt
  review     SimulatorReview    @relation(fields: [reviewId], references: [id])
  reviewType SimulatorReviewType @relation(fields: [typeId], references: [id])

  @@id([reviewId, typeId])
  @@map("reviewlist")
}


model CustomerReview {
  id        Int      @id @default(autoincrement())
  rating    Int      @db.SmallInt // 1-5 stars
  comment   String?  @db.Text
  bookingId Int      @unique // One customer review per booking
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking   Booking  @relation("BookingCustomerReview", fields: [bookingId], references: [id])

  @@map("customer_review")
}


enum FacilityCategory {
  HARDWARE
  GAMES_AND_CONTENT
  SEATING_AND_MOTION
  CONNECTIVITY
  ENVIRONMENT
  VENUE
}

model Facility {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar(100)
  icon        String?           @db.VarChar(50)  // Icon identifier (e.g. "wifi", "parking")
  category    FacilityCategory

  simulators  SimulatorFacility[]

  @@map("facility")
}

model SimulatorFacility {
  simId       Int
  facilityId  Int
  assignedAt  DateTime  @default(now())

  simulator   Simulator @relation(fields: [simId], references: [id], onDelete: Cascade)
  facility    Facility  @relation(fields: [facilityId], references: [id])

  @@id([simId, facilityId])
  @@map("simulator_facility")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
  BANNED
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  DISMISSED
}


model Admin {
  id          Int         @id @default(autoincrement())
  username    String      @unique @db.VarChar(100)
  password    String      @db.VarChar(255)
  email       String      @unique @db.VarChar(255)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  @@map("admin")
}

model CustomerReport {
  id            Int           @id @default(autoincrement())
  reason        String        @db.Text
  status        ReportStatus  @default(PENDING)
  adminNote     String?       @db.Text
  createdAt     DateTime      @default(now())
  resolvedAt    DateTime?
  userId    Int           @map("CustomerID")
  user     User          @relation("CustomerReports", fields: [userId], references: [id])
  
  @@map("report")
}
