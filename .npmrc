# NPM Security Configuration - Supply Chain Attack Prevention

# Always save exact versions (no ^ or ~) to prevent unexpected updates
save-exact=true

# Enable package-lock.json integrity checks
package-lock=true

# Audit on install - fail on high/critical vulnerabilities
audit=true
audit-level=moderate

# Only install from official npm registry (prevent registry hijacking)
registry=https://registry.npmjs.org/

# Verify package signatures when available
# (Node 16.17+, npm 9+ supports this)
# Note: Not all packages are signed yet, so this is informational
ignore-scripts=true

# Log level for better visibility
loglevel=warn

# Prevent automatic execution of lifecycle scripts from untrusted packages
# Uncomment if you want maximum security (may break some packages):
# ignore-scripts=true

# Engine strict - enforce Node version compatibility
engine-strict=true
